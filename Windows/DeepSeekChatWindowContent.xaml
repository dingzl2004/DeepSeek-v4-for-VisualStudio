<DataTemplate xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
              xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
              xmlns:vs="http://schemas.microsoft.com/visualstudio/extensibility/2022/xaml"
              xmlns:styles="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
              xmlns:colors="clr-namespace:Microsoft.VisualStudio.PlatformUI;assembly=Microsoft.VisualStudio.Shell.15.0">
    <Grid Margin="0">
        <Grid.Resources>
            <!-- ═══ 基础控件样式 ═══ -->
            <Style TargetType="TextBox">
                <Setter Property="Padding" Value="4" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="BorderBrush" Value="#888888" />
                <Setter Property="Background" Value="#2D2D2D" />
                <Setter Property="Foreground" Value="#D4D4D4" />
                <Setter Property="CaretBrush" Value="#D4D4D4" />
            </Style>
            <Style TargetType="Button">
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="Background" Value="#3C3C3C" />
                <Setter Property="Foreground" Value="#D4D4D4" />
                <Setter Property="BorderBrush" Value="#555555" />
                <Setter Property="BorderThickness" Value="1" />
            </Style>
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="#2D2D2D" />
                <Setter Property="Foreground" Value="#D4D4D4" />
                <Setter Property="BorderBrush" Value="#555555" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="8,4" />
                <Setter Property="MinWidth" Value="80" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 切换按钮 (ToggleButton) -->
                                <ToggleButton Name="ToggleButton" 
                                              Grid.Row="0" 
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              Background="{TemplateBinding Background}"
                                              BorderBrush="{TemplateBinding BorderBrush}"
                                              BorderThickness="{TemplateBinding BorderThickness}"
                                              Foreground="{TemplateBinding Foreground}">

                                    <!-- 自定义 ToggleButton 模板 -->
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border x:Name="Border"
                                                    Background="{TemplateBinding Background}"
                                                    BorderBrush="{TemplateBinding BorderBrush}"
                                                    BorderThickness="{TemplateBinding BorderThickness}"
                                                    Padding="{TemplateBinding Padding}">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- 当前选中的内容 -->
                                                    <ContentPresenter Grid.Column="0" 
                                                                      Margin="6,0,0,0"
                                                                      Content="{Binding SelectionBoxItem, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      ContentTemplate="{Binding SelectionBoxItemTemplate, RelativeSource={RelativeSource AncestorType=ComboBox}}"
                                                                      HorizontalAlignment="Stretch" 
                                                                      VerticalAlignment="Center" />

                                                    <!-- 下拉箭头 -->
                                                    <Path Grid.Column="1" 
                                                          Data="M 0 0 L 4 4 L 8 0" 
                                                          Stroke="#888888" 
                                                          StrokeThickness="1" 
                                                          Fill="Transparent" 
                                                          VerticalAlignment="Center" 
                                                          Margin="0,0,8,0" />
                                                </Grid>
                                            </Border>

                                            <ControlTemplate.Triggers>
                                                <!-- 鼠标悬停时 -->
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#3E3E42" />
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#777777" />
                                                </Trigger>
                                                <!-- 下拉菜单打开时 -->
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Border" Property="Background" Value="#2D2D2D" />
                                                    <Setter TargetName="Border" Property="BorderBrush" Value="#6CAFD9" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>

                                <!-- 下拉弹窗 -->
                                <Popup Name="Popup" 
                                       IsOpen="{Binding IsDropDownOpen, RelativeSource={RelativeSource TemplatedParent}}" 
                                       PlacementTarget="{Binding ElementName=ToggleButton}" 
                                       Placement="Bottom" 
                                       StaysOpen="False" 
                                       AllowsTransparency="True">
                                    <Border Background="#2D2D2D" 
                                            BorderBrush="#555555" 
                                            BorderThickness="1" 
                                            CornerRadius="4" 
                                            Margin="0,2,0,0">
                                        <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="300">
                                            <ItemsPresenter />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="#D4D4D4" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="Padding" Value="8,6" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}" 
                                    CornerRadius="2">
                                <ContentPresenter Content="{TemplateBinding Content}" 
                                                  ContentTemplate="{TemplateBinding ContentTemplate}" 
                                                  ContentStringFormat="{TemplateBinding ContentStringFormat}" 
                                                  Margin="{TemplateBinding Padding}" 
                                                  HorizontalAlignment="Stretch" 
                                                  VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <!-- 鼠标悬停状态 -->
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#3E3E42" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                </Trigger>
                                <!-- 选中状态 -->
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter Property="Background" Value="#264F78" />
                                    <Setter Property="Foreground" Value="#FFFFFF" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="#D4D4D4" />
            </Style>

            <!-- 用户消息气泡 -->
            <Style x:Key="UserBubbleStyle" TargetType="Border">
                <Setter Property="Background" Value="#264F78" />
                <Setter Property="BorderBrush" Value="#3A6DA5" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Margin" Value="48,6,12,6" />
                <Setter Property="MaxWidth" Value="520" />
                <Setter Property="HorizontalAlignment" Value="Right" />
            </Style>

            <!-- DeepSeek 消息气泡 -->
            <Style x:Key="AssistantBubbleStyle" TargetType="Border">
                <Setter Property="Background" Value="#2D2D2D" />
                <Setter Property="BorderBrush" Value="#555555" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Margin" Value="12,6,48,6" />
                <Setter Property="MaxWidth" Value="520" />
                <Setter Property="HorizontalAlignment" Value="Left" />
            </Style>

            <!-- 角色标签 -->
            <Style x:Key="RoleLabelStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="Bold" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Margin" Value="0,0,0,4" />
                <Setter Property="Foreground" Value="#888888" />
            </Style>

            <!-- 消息文本 -->
            <Style x:Key="MsgTextStyle" TargetType="TextBlock">
                <Setter Property="TextWrapping" Value="Wrap" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="LineHeight" Value="20" />
                <Setter Property="Foreground" Value="#D4D4D4" />
            </Style>

            <!-- 状态栏文本 -->
            <Style x:Key="StatusStyle" TargetType="TextBlock">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Foreground" Value="#888888" />
                <Setter Property="Margin" Value="8,2" />
            </Style>
        </Grid.Resources>

        <!-- ═══ 主布局 ═══ -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <!-- 状态显示 -->
                <RowDefinition Height="Auto" />
                <!-- 组合输入区 -->
            </Grid.RowDefinitions>

            <!-- ─── 消息列表 ─── -->
            <ListBox Grid.Row="0"
                     ItemsSource="{Binding Messages}"
                     SelectedIndex="{Binding SelectedMessageIndex, Mode=OneWay}"
                     Background="#1E1E1E"
                     BorderThickness="0"
                     Margin="0" Padding="4"
                     HorizontalContentAlignment="Stretch"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Focusable" Value="False" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter />
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <Border Style="{StaticResource UserBubbleStyle}"
                                        x:Name="UserBubble" Visibility="Collapsed">
                                    <StackPanel>
                                        <TextBlock Text="你" Style="{StaticResource RoleLabelStyle}" />
                                        <TextBlock Text="{Binding Content}" Style="{StaticResource MsgTextStyle}" />
                                    </StackPanel>
                                </Border>

                                <Border Style="{StaticResource AssistantBubbleStyle}"
                                        x:Name="AssistantBubble" Visibility="Collapsed">
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                                            <TextBlock Text="DeepSeek"
                                                       Style="{StaticResource RoleLabelStyle}" Margin="0,0,8,0" />
                                            <TextBlock Text="●●●" x:Name="StreamingDots"
                                                       Foreground="#6CAFD9"
                                                       FontSize="10" Visibility="Collapsed" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding Content}" Style="{StaticResource MsgTextStyle}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Role}" Value="user">
                                    <Setter TargetName="UserBubble" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Role}" Value="assistant">
                                    <Setter TargetName="AssistantBubble" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsStreaming}" Value="True">
                                    <Setter TargetName="StreamingDots" Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- ─── 状态显示 ─── -->
            <TextBlock Grid.Row="1" Text="{Binding StatusText}" Style="{StaticResource StatusStyle}" Margin="12,4,12,0" />

            <!-- ─── 组合输入区 ─── -->
            <Border Grid.Row="2"
                    BorderBrush="#444444"
                    BorderThickness="1"
                    CornerRadius="6"
                    Background="#2D2D2D"
                    Margin="8,4,8,12" Padding="4">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBox Grid.Row="0"
                             Text="{Binding InputText, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="50" MaxHeight="140"
                             Background="Transparent" BorderThickness="0"
                             VerticalScrollBarVisibility="Auto"
                             VerticalContentAlignment="Top" Padding="4">
                        <TextBox.InputBindings>
                            <KeyBinding Key="Enter" Command="{Binding SendCommand}" />
                        </TextBox.InputBindings>
                    </TextBox>

                    <!-- Bottom Toolbar -->
                    <Grid Grid.Row="1" Margin="4,8,4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Left Toolbar -->
                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <TextBlock Text="⚡" Foreground="#888888" VerticalAlignment="Center" Margin="0,0,4,0" FontSize="14" />
                                <ComboBox ItemsSource="{Binding AvailableModels}"
                                SelectedItem="{Binding SelectedModel}"
                                BorderThickness="0"
                                MinWidth="110" Margin="0,0,12,0" />

                                <CheckBox IsChecked="{Binding IsThinkingEnabled}"
                                      Content="深度思考"
                                      VerticalAlignment="Center" Margin="0,0,8,0" />

                                 <ComboBox ItemsSource="{Binding ReasoningEfforts}"
                                SelectedItem="{Binding ReasoningEffort}"
                                BorderThickness="0"
                                MinWidth="60"
                                Visibility="{Binding IsThinkingEnabled, Converter={StaticResource BooleanToVisibilityConverter}}" />
                        </StackPanel>

                        <!-- Right Toolbar -->
                        <StackPanel Grid.Column="2" Orientation="Horizontal">
                            <Button Content="清空" Command="{Binding ClearCommand}" ToolTip="清空对话" Background="Transparent" BorderThickness="0" Margin="0,0,4,0" />
                            <Button Content="停止" Command="{Binding StopCommand}" ToolTip="停止生成" Background="Transparent" BorderThickness="0" Margin="0,0,4,0" />
                            <Button Content="⚙" Command="{Binding OpenConfigCommand}" ToolTip="配置 API 密钥" Background="Transparent" BorderThickness="0" Margin="0,0,4,0" FontSize="14" />
                            <Button Content="➤" Command="{Binding SendCommand}" ToolTip="发送 (Enter)" Background="Transparent" BorderThickness="0" Foreground="#6CAFD9" FontSize="14" Padding="8,0" />
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</DataTemplate>